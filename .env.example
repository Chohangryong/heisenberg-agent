# ─── heisenberg.kr login ───
HEISENBERG_USERNAME_OR_EMAIL=
HEISENBERG_PASSWORD=

# ─── LLM API keys ───
ANTHROPIC_API_KEY=          # Primary analyzer (Claude)
OPENAI_API_KEY=             # Fallback analyzer (GPT-4o) + embeddings

# ─── Notion sync ───
NOTION_API_KEY=
NOTION_DATA_SOURCE_ID=             # 필수 (notion.enabled=True일 때). Data Source UUID
NOTION_PARENT_PAGE_ID=             # 선택. DB/data source 자동 생성 시에만

# ─── App ───
LOG_LEVEL=INFO
